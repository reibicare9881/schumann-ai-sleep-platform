// ══ APPOINTMENT SCREEN ═══════════════════════════════════
const ApptScreen=({session,onBack})=>{
  const today=new Date().toISOString().slice(0,10);
  const isAdmin=session.systemRole==="admin";
  const[tab,setTab]=useState("schumann");
  const[slots,setSlots]=useState([]);
  const[viewMode,setViewMode]=useState(isAdmin?"view":"book");
  const[filterDate,setFilterDate]=useState("");
  const[form,setForm]=useState({date:today,time:"09:00",name:session?.name||"",note:""});
  const[msg,setMsg]=useState("");
  const SVCS={schumann:{label:"〰️ 舒曼共振減壓",color:C.teal,desc:"REIBI Schumann Resonance 7.83Hz · 30–45分鐘"},laser:{label:"⚡ 激光物理干預",color:C.coral,desc:"REIBI LA200 低能量雷射 · 10–15分鐘"}};
  const TIMES=["08:30","09:00","09:30","10:00","10:30","11:00","11:30","13:00","13:30","14:00","14:30","15:00","15:30","16:00","16:30","17:00"];
  const loadSlots=()=>{const code=session.orgCode||"personal";DB.getAppts(code,tab).then(d=>setSlots(Array.isArray(d)?d:[]));};
  useEffect(()=>loadSlots(),[tab,session.orgCode]);
  const book=async()=>{if(!form.name||!form.date||!form.time){setMsg("請填寫日期、時間與姓名");return;}const clash=slots.find(s=>s.date===form.date&&s.time===form.time&&s.status!=="cancelled");if(clash){setMsg("此時段已被預約，請選擇其他時間");return;}const appt={id:Date.now().toString(36),date:form.date,time:form.time,name:form.name,note:form.note,status:"booked",service:tab,bookedAt:new Date().toISOString()};const updated=[...slots,appt].sort((a,b)=>a.date+a.time>b.date+b.time?1:-1);const code=session.orgCode||"personal";await DB.setAppts(code,tab,updated);setMsg("✅ 預約成功！"+form.date+" "+form.time);setForm({...form,note:""});loadSlots();};
  const complete=async id=>{const updated=slots.map(s=>s.id===id?{...s,status:"completed",completedAt:new Date().toISOString()}:s);const apptCode=session.orgCode||"personal";await DB.setAppts(apptCode,tab,updated);setMsg("✅ 療程紀錄已更新");loadSlots();};
  const cancel=async id=>{const updated=slots.map(s=>s.id===id?{...s,status:"cancelled"}:s);const code=session.orgCode||"personal";await DB.setAppts(code,tab,updated);setMsg("已取消預約");loadSlots();};
  const upcoming=slots.filter(s=>s.status!=="cancelled"&&(isAdmin&&viewMode==="view"?true:s.date>=today)).filter(s=>!filterDate||s.date===filterDate);
  const completedLog=slots.filter(s=>s.status==="completed");
  const svc=SVCS[tab];
  const exportAppts=()=>{const rows=["自主健管預約排程","服務："+svc.label,"","日期\t時間\t預約者\t備註",...upcoming.map(a=>`${a.date}\t${a.time}\t${a.name}\t${a.note||""}`)].join("\n");const b=new Blob([rows],{type:"text/plain;charset=utf-8"});const u=URL.createObjectURL(b);const a=document.createElement("a");a.href=u;a.download=`自主健管預約排程_${svc.label}.txt`;a.click();URL.revokeObjectURL(u);};
  return <div>
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:14}}><h2 style={{margin:0,color:C.text,fontSize:16}}>📅 自主健管預約排程</h2><button onClick={onBack} style={{padding:"7px 12px",borderRadius:7,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,fontSize:11,cursor:"pointer"}}>← 返回</button></div>
    <div style={{display:"flex",gap:8,marginBottom:11}}>{Object.entries(SVCS).map(([k,s])=><button key={k} onClick={()=>setTab(k)} style={{flex:1,padding:"10px",borderRadius:9,cursor:"pointer",border:tab===k?`1.5px solid ${s.color}`:`1px solid ${C.border}`,background:tab===k?`${s.color}15`:"#faf8f5",color:tab===k?s.color:C.muted,fontWeight:tab===k?700:400,fontSize:11}}>{s.label}</button>)}</div>
    <div style={{background:`${svc.color}10`,border:`1px solid ${svc.color}33`,borderRadius:9,padding:"8px 12px",marginBottom:11,fontSize:10,color:svc.color}}>🏥 {svc.label} · {svc.desc}</div>
    {isAdmin&&<div style={{display:"flex",gap:8,marginBottom:11}}>{[{k:"view",l:"📋 查閱全部排程"},{k:"book",l:"📅 新增預約"}].map(m=><button key={m.k} onClick={()=>setViewMode(m.k)} style={{flex:1,padding:"8px",borderRadius:8,cursor:"pointer",fontSize:11,fontWeight:600,border:viewMode===m.k?`1.5px solid ${svc.color}`:`1px solid ${C.border}`,background:viewMode===m.k?`${svc.color}15`:"#faf8f5",color:viewMode===m.k?svc.color:C.muted}}>{m.l}</button>)}</div>}
    {(!isAdmin||viewMode==="book")&&<div style={{background:"#fff",border:`1px solid ${C.border}`,borderRadius:10,padding:"14px",marginBottom:11}}>
      <div style={{fontSize:11,color:svc.color,fontWeight:700,marginBottom:10}}>📅 新增預約</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:9}}><div><div style={{fontSize:10,color:C.muted,marginBottom:4}}>日期</div><input type="date" value={form.date} min={today} onChange={e=>setForm({...form,date:e.target.value})} style={{width:"100%",padding:"8px 10px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:12,outline:"none",boxSizing:"border-box"}}/></div><div><div style={{fontSize:10,color:C.muted,marginBottom:4}}>時間</div><select value={form.time} onChange={e=>setForm({...form,time:e.target.value})} style={{width:"100%",padding:"8px 10px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:12,outline:"none"}}>{TIMES.map(t=><option key={t} value={t}>{t}</option>)}</select></div></div>
      <div style={{marginBottom:9}}><div style={{fontSize:10,color:C.muted,marginBottom:4}}>預約者姓名</div><input value={form.name} onChange={e=>setForm({...form,name:e.target.value})} placeholder="請輸入姓名" style={{width:"100%",padding:"8px 10px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:12,outline:"none",boxSizing:"border-box"}}/></div>
      <div style={{marginBottom:11}}><div style={{fontSize:10,color:C.muted,marginBottom:4}}>備註（選填）</div><input value={form.note} onChange={e=>setForm({...form,note:e.target.value})} placeholder="特殊需求、聯絡方式" style={{width:"100%",padding:"8px 10px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:12,outline:"none",boxSizing:"border-box"}}/></div>
      {msg&&<div style={{fontSize:11,color:msg.includes("✅")?C.sage:C.coral,marginBottom:8,padding:"6px 10px",background:msg.includes("✅")?"#edf7f3":"#fdf0f0",borderRadius:7}}>{msg}</div>}
      <button onClick={book} style={{width:"100%",padding:"11px",borderRadius:8,border:"none",background:`linear-gradient(135deg,${svc.color},${svc.color}cc)`,color:"#fff",fontSize:13,fontWeight:600,cursor:"pointer"}}>確認預約</button>
