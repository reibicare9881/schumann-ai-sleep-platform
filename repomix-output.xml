// ══ LOGIN SCREEN ═════════════════════════════════════════
const LoginScreen=({onLogin})=>{
  const[mode,setMode]=useState(null);
  const[loading,setLoading]=useState(false);
  const[err,setErr]=useState("");
  // Individual
  const[iName,setIName]=useState("");
  // Org - persistent fields
  const[oName,setOName]=useState("");
  const[oCode,setOCode]=useState("");
  const[oOrgName,setOOrgName]=useState("");
  const[oRole,setORole]=useState("member");
  const[pin,setPin]=useState("");
  // First-time setup (admin only)
  const[isFirstTime,setIsFirstTime]=useState(null);
  const[setupMPin,setSetupMPin]=useState("");
  const[setupDPin,setSetupDPin]=useState("");
  const[setupAPin,setSetupAPin]=useState("");

  // Auto-fill org name when code is entered
  useEffect(()=>{
    if(mode==="org"&&oCode.length>=3){
      const code=oCode.toUpperCase();
      DB.getCreds(code).then(c=>{
        setIsFirstTime(!c);
        if(c?.orgName&&!oOrgName)setOOrgName(c.orgName);
      });
    }else setIsFirstTime(null);
  },[mode,oCode]);

  // Load saved identity for returning members
  useEffect(()=>{
    if(mode==="org"&&oCode.length>=3&&oRole!=="admin"){
      stor.get("mem_id_"+oCode.toUpperCase()+"_"+oRole).then(d=>{
        if(d?.name&&!oName)setOName(d.name);
      });
    }
  },[mode,oCode,oRole]);

  const doI=async()=>{
    if(!iName.trim()){setErr("請輸入姓名或代稱");return;}
    setLoading(true);
    const s={uid:Date.now().toString(36),name:iName.trim(),systemRole:"individual",loginTs:new Date().toISOString()};
    await DB.saveSession(s);onLogin(s);
  };

  const doO=async()=>{
    setErr("");
    if(!oCode.trim()||!oName.trim()){setErr("請填寫姓名與單位代碼");return;}
    const code=oCode.trim().toUpperCase();
    setLoading(true);
    let creds=await DB.getCreds(code);

    if(!creds){
      // Only admin can do first-time setup
      if(oRole!=="admin"){setLoading(false);setErr("此單位尚未設定，請聯絡單位平台管理者完成首次設定");return;}
      if(!oOrgName.trim()){setLoading(false);setErr("首次設定：請填寫單位名稱");return;}
      if(!setupMPin||setupMPin.length<4){setLoading(false);setErr("首次設定：成員通行碼至少4碼");return;}
      if(!setupDPin||setupDPin.length<4){setLoading(false);setErr("首次設定：部門主管通行碼至少4碼");return;}
      if(!setupAPin||setupAPin.length<4){setLoading(false);setErr("首次設定：管理者通行碼至少4碼");return;}
      const pins=[setupMPin,setupDPin,setupAPin];
      if(new Set(pins).size!==3){setLoading(false);setErr("三組通行碼必須各不相同");return;}
      creds={orgName:oOrgName.trim(),memberPin:setupMPin,deptPin:setupDPin,adminPin:setupAPin,createdAt:new Date().toISOString()};
      await DB.setCreds(code,creds);
    }else{
      // Verify by role
      const expect={member:creds.memberPin,dept_head:creds.deptPin,admin:creds.adminPin}[oRole];
      if(pin!==expect){setLoading(false);setErr(`${ROLES[oRole]?.label}通行碼錯誤`);return;}
    }

    // Save member identity for next login (non-admin only)
    if(oRole!=="admin")await stor.set("mem_id_"+code+"_"+oRole,{name:oName.trim(),orgName:creds.orgName});

    const s={uid:Date.now().toString(36),name:oName.trim(),orgCode:code,orgName:creds.orgName,systemRole:oRole,loginTs:new Date().toISOString(),_pin:pin||setupAPin||""};
    await DB.saveSession(s);onLogin(s);
  };

  const nonAdminRoles=Object.entries(ROLES).filter(([k])=>k!=="individual");

  return (
    <div style={{paddingTop:4}}>
      <MissionBanner/>
      <div style={{textAlign:"center",marginBottom:18}}><h1 style={{fontSize:"clamp(16px,5vw,22px)",fontWeight:700,color:C.text,margin:"0 0 4px"}}>健康自主管理評估系統</h1><p style={{color:C.muted,fontSize:11,margin:"0 0 3px"}}>睡眠 × 疼痛聯合評估 · ISI &amp; BPI 國際量表</p></div>

      {!mode&&<div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:11,maxWidth:400,margin:"0 auto"}}>{[{k:"individual",icon:"👤",title:"個人使用",desc:"個人健康自主管理\n完整存取個人報告",color:C.teal},{k:"org",icon:"🏢",title:"單位 / 組織",desc:"多層級角色分權\nOKR績效管理",color:C.plum}].map(m=><button key={m.k} onClick={()=>{setMode(m.k);setErr("");}} style={{background:"#fff",border:`1px solid ${C.border}`,borderRadius:13,padding:"19px 10px",cursor:"pointer",textAlign:"center",boxShadow:C.shadow}}><div style={{fontSize:27,marginBottom:7}}>{m.icon}</div><div style={{fontSize:12,fontWeight:700,marginBottom:3,color:m.color}}>{m.title}</div><div style={{fontSize:10,color:C.muted,lineHeight:1.6,whiteSpace:"pre-line"}}>{m.desc}</div></button>)}</div>}

      {mode==="individual"&&<Card style={{maxWidth:400,margin:"0 auto"}}>
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:13}}><button onClick={()=>{setMode(null);setErr("");}} style={{background:"transparent",border:"none",color:C.muted,cursor:"pointer",fontSize:17,padding:0}}>←</button><div style={{fontSize:13,fontWeight:700,color:C.text}}>👤 個人登入</div></div>
        <F label="姓名 / 代稱"><Inp value={iName} onChange={setIName} placeholder="請輸入姓名或代稱"/></F>
        <div style={{background:"#fdf6e8",border:`1px solid #f0d898`,borderRadius:7,padding:"7px 11px",marginBottom:11,fontSize:11,color:"#6b4a10"}}>💡 個人模式資料僅儲存於本裝置。</div>
        {err&&<div style={{color:"#b82020",fontSize:11,marginBottom:8}}>⚠ {err}</div>}
        <button onClick={doI} disabled={loading} style={{width:"100%",padding:"12px",borderRadius:9,border:"none",background:loading?C.faint:`linear-gradient(135deg,${C.teal},#1a6474)`,color:"#fff",fontSize:14,fontWeight:600,cursor:"pointer"}}>{loading?"請稍候…":"進入個人模式 →"}</button>
      </Card>}

      {mode==="org"&&<Card style={{maxWidth:520,margin:"0 auto"}}>
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:13}}>
          <button onClick={()=>{setMode(null);setErr("");setIsFirstTime(null);}} style={{background:"transparent",border:"none",color:C.muted,cursor:"pointer",fontSize:17,padding:0}}>←</button>
          <div style={{fontSize:13,fontWeight:700,color:C.text}}>🏢 單位登入</div>
          {isFirstTime===true&&<span style={{marginLeft:"auto",fontSize:10,color:C.sage,background:C.sageBg,padding:"2px 9px",borderRadius:20}}>🆕 首次設定</span>}
          {isFirstTime===false&&<span style={{marginLeft:"auto",fontSize:10,color:C.teal,background:C.tealBg,padding:"2px 9px",borderRadius:20}}>✅ 已建立單位</span>}
        </div>

        <F label="您的姓名 / 代稱（去識別化）"><Inp value={oName} onChange={setOName} placeholder="個人識別用（不公開）"/></F>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:11}}>
          <F label="單位代碼" mb={0}><Inp value={oCode} onChange={v=>setOCode(v.toUpperCase())} placeholder="例：LIMEI001"/></F>
          <F label="單位名稱" mb={0}><Inp value={oOrgName} onChange={setOOrgName} placeholder="例：麗媚生化科技"/></F>
        </div>

        <F label="登入角色">
          <div style={{display:"flex",flexDirection:"column",gap:5}}>
            {nonAdminRoles.map(([k,r])=>(
              <div key={k} onClick={()=>setORole(k)} style={{display:"flex",alignItems:"flex-start",gap:8,padding:"8px 11px",borderRadius:9,cursor:"pointer",border:oRole===k?`1.5px solid ${r.color}`:`1px solid ${C.border}`,background:oRole===k?`${r.color}10`:"#faf8f5"}}>
                <div style={{width:12,height:12,borderRadius:"50%",flexShrink:0,marginTop:2,border:`2px solid ${oRole===k?r.color:C.faint}`,background:oRole===k?r.color:"transparent"}}/>
                <div><div style={{fontSize:11,fontWeight:600,color:r.color}}>{r.icon} {r.label}</div><div style={{fontSize:10,color:C.muted,marginTop:1}}>{r.desc}</div></div>
              </div>
            ))}
          </div>
        </F>

        {/* Non-admin PIN input */}
        {isFirstTime===false&&(
          <div style={{background:"#faf8f5",border:`1px solid ${C.border}`,borderRadius:9,padding:"12px",marginBottom:10}}>
            <div style={{fontSize:11,color:C.teal,fontWeight:700,marginBottom:8}}>🔐 {ROLES[oRole]?.label}通行碼</div>
            <F label={`請輸入由單位管理者設定的${ROLES[oRole]?.label}通行碼`} mb={0}>
              <Inp value={pin} onChange={setPin} type="password" placeholder="請輸入通行碼"/>
            </F>
          </div>
        )}

        {isFirstTime===true&&oRole!=="admin"&&<div style={{background:"#fdf0f0",border:`1px solid #f0a0a0`,borderRadius:8,padding:"9px 12px",marginBottom:10,fontSize:11,color:"#b82020"}}>⚠ 此單位尚未初始化。請先由<strong>單位平台管理者</strong>選擇「單位平台管理者」角色完成首次設定，並告知各角色通行碼。</div>}

        {/* Admin first-time setup */}
        {isFirstTime===true&&oRole==="admin"&&(
          <div style={{background:C.plumBg,border:`1px solid ${C.plum}44`,borderRadius:9,padding:"13px",marginBottom:10}}>
            <div style={{fontSize:11,color:C.plum,fontWeight:700,marginBottom:4}}>🆕 首次設定（單位平台管理者專屬）</div>
            <div style={{fontSize:10,color:C.muted,lineHeight:1.7,marginBottom:11}}>請同時設定三組通行碼。設定完成後，請將對應通行碼分發給各角色成員。三組通行碼必須各不相同。</div>
            <F label="① 單位成員通行碼（≥4碼）"><Inp value={setupMPin} onChange={setSetupMPin} type="password" placeholder="設定後分發給所有成員"/></F>
            <F label="② 部門主管通行碼（≥4碼）"><Inp value={setupDPin} onChange={setSetupDPin} type="password" placeholder="設定後分發給各部門主管"/></F>
            <F label="③ 管理者通行碼（≥4碼，您自己使用）" mb={0}><Inp value={setupAPin} onChange={setSetupAPin} type="password" placeholder="管理者登入使用" style={{borderColor:`${C.coral}44`}}/></F>
          </div>
        )}

        {isFirstTime===false&&oRole==="admin"&&(
          <div style={{background:C.plumBg,border:`1px solid ${C.plum}44`,borderRadius:9,padding:"12px",marginBottom:10}}>
            <div style={{fontSize:11,color:C.plum,fontWeight:700,marginBottom:8}}>🔐 管理者通行碼</div>
            <F label="請輸入管理者通行碼" mb={0}><Inp value={pin} onChange={setPin} type="password" placeholder="管理者通行碼"/></F>
          </div>
        )}

        {err&&<div style={{color:"#b82020",fontSize:11,marginBottom:8,padding:"6px 10px",background:"#fdf0f0",borderRadius:7}}>⚠ {err}</div>}
        <button onClick={doO} disabled={loading} style={{width:"100%",padding:"12px",borderRadius:9,border:"none",background:loading?C.faint:`linear-gradient(135deg,${C.plum},#5a3a7c)`,color:"#fff",fontSize:14,fontWeight:600,cursor:"pointer"}}>{loading?"驗證中…":"進入單位模式 →"}</button>

        {/* Permission table */}
        <div style={{marginTop:14,paddingTop:12,borderTop:`1px solid ${C.divider}`}}>
          <div style={{fontSize:10,color:C.muted,fontWeight:600,marginBottom:8,textAlign:"center"}}>🔑 各角色權限說明</div>
          <div style={{overflowX:"auto"}}>
            <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
              <thead><tr style={{background:"#faf8f5"}}><th style={{padding:"5px 7px",textAlign:"left",color:C.muted,borderBottom:`1px solid ${C.border}`}}>功能</th>{nonAdminRoles.concat([["admin",ROLES.admin]]).map(([k,r])=><th key={k} style={{padding:"5px 4px",textAlign:"center",color:r.color,borderBottom:`1px solid ${C.border}`,minWidth:48}}>{r.icon}<div style={{fontSize:7,marginTop:1}}>{r.label}</div></th>)}</tr></thead>
              <tbody>{PERMS.filter(p=>!["individual"].some(r=>p.roles.includes(r)&&p.roles.length===1)).map((row,i)=><tr key={row.p} style={{background:i%2===0?"#fff":"#faf8f5"}}><td style={{padding:"4px 7px",color:C.text,borderBottom:`1px solid ${C.divider}`}}>{row.label}</td>{["member","dept_head","admin"].map(role=><td key={role} style={{padding:"4px 4px",textAlign:"center",borderBottom:`1px solid ${C.divider}`}}>{row.roles.includes(role)?<span style={{color:"#2d7a5a",fontSize:12}}>✓</span>:<span style={{color:"#e8ddd4"}}>—</span>}</td>)}</tr>)}</tbody>
            </table>
          </div>
        </div>
      </Card>}
    </div>
  );
};

// ══ DASHBOARD ════════════════════════════════════════════
const Dashboard=({session,history=[],onNav,onLogout})=>{
  const r=ROLES[session.systemRole]||ROLES.individual;
  const safe=Array.isArray(history)?history:[];
  const isAdmin=session.systemRole==="admin";
  const tiles=[
    {icon:"📝",label:"開始健康評估",sub:"填寫問卷，生成個人報告",color:C.teal,action:"assess",show:can(session.systemRole,"assess")},
    {icon:"📋",label:"查閱個人報告",sub:`共 ${safe.length} 筆記錄`,color:C.sage,action:"history",show:can(session.systemRole,"view_history")},
    {icon:"📊",label:"單位KPI報表",sub:"去識別化統計分析",color:C.plum,action:"org",show:can(session.systemRole,"view_org")||can(session.systemRole,"view_dept_okr")},
    {icon:"🎯",label:"OKR績效儀表板",sub:"健康成果 × 獎酬激勵",color:C.amber,action:"okr",show:can(session.systemRole,"view_okr")||can(session.systemRole,"view_dept_okr")},
    {icon:"📅",label:"自主健管預約排程",sub:isAdmin?"查閱/修改/下載/列印全單位":"舒曼波 / 激光物理干預",color:C.teal,action:"appt",show:can(session.systemRole,"view_appt")},
    {icon:"🌱",label:"ESG健康效益",sub:"降本/增效/社會責任",color:C.sage,action:"esg",show:can(session.systemRole,"view_esg")},
    {icon:"📊",label:"健康分析 & 趨勢",sub:"睡眠/疼痛曲線・預測",color:C.teal,action:"analysis",show:can(session.systemRole,"view_history")},
    {icon:"🔴",label:"高風險族群分析",sub:"健康分布・介入建議",color:"b82020",action:"highrisk",show:can(session.systemRole,"view_org")||can(session.systemRole,"view_dept_okr")},
    {icon:"🔒",label:"隱私 & 安全中心",sub:"加密機制・法規・稽核",color:C.plum,action:"privacy",show:true},
  ].filter(t=>t.show);
  return (
    <div>
      <div style={{background:`linear-gradient(135deg,${r.color}22,${r.color}10)`,border:`1px solid ${r.color}44`,borderRadius:12,padding:"14px 16px",marginBottom:15}}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <div style={{fontSize:26,background:`${r.color}20`,borderRadius:9,width:44,height:44,display:"flex",alignItems:"center",justifyContent:"center"}}>{r.icon}</div>
            <div><div style={{fontSize:14,fontWeight:700,color:C.text}}>{session.name}</div><Badge role={session.systemRole}/>{session.orgName&&<div style={{fontSize:10,color:C.muted,marginTop:1}}>🏢 {session.orgName}</div>}</div>
          </div>
          <button onClick={onLogout} style={{padding:"5px 11px",borderRadius:7,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,fontSize:11,cursor:"pointer"}}>登出</button>
        </div>
        {isAdmin&&<div style={{marginTop:9,fontSize:10,color:C.plum,background:`${C.plum}10`,borderRadius:7,padding:"6px 10px"}}>🔐 單位平台管理者 · HR人資高管/財務高管/負責人 · 可修改編輯所有報表參數</div>}
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:14}}>
        {tiles.map(t=>(
          <button key={t.action} onClick={()=>onNav(t.action)} style={{background:"#fff",border:`1px solid ${C.border}`,borderRadius:12,padding:"14px 11px",cursor:"pointer",textAlign:"left",boxShadow:C.shadow}}>
            <div style={{fontSize:22,marginBottom:5}}>{t.icon}</div>
            <div style={{fontSize:11,fontWeight:700,color:t.color,marginBottom:2}}>{t.label}</div>
            <div style={{fontSize:10,color:C.muted}}>{t.sub}</div>
          </button>
        ))}
      </div>
      {safe.length>0&&<Card style={{background:"#fdf9f5"}}><div style={{fontSize:11,color:C.teal,fontWeight:600,marginBottom:9}}>📈 最近評估記錄</div>{safe.slice(0,3).map((rec,i)=>{const d=new Date(rec.ts).toLocaleDateString("zh-TW",{month:"short",day:"numeric"});const sk=rec.sLevel?.key||"green";const pk=rec.pLevel?.key||"green";return <div key={rec.id||i} style={{display:"flex",alignItems:"center",gap:9,padding:"7px 10px",borderRadius:8,marginBottom:5,background:"#fff",border:`1px solid ${C.border}`}}><div style={{width:19,height:19,borderRadius:"50%",flexShrink:0,background:`linear-gradient(135deg,${LX[sk].c},${LX[pk].c})`,fontSize:8,fontWeight:700,display:"flex",alignItems:"center",justifyContent:"center",color:"#fff"}}>{i+1}</div><div style={{flex:1}}><div style={{fontSize:11,color:C.text,fontWeight:600}}>{d}</div><div style={{display:"flex",gap:6,fontSize:10}}><span style={{color:LX[sk].c}}>睡眠 {rec.sScore}/28</span><span style={{color:C.faint}}>·</span><span style={{color:LX[pk].c}}>疼痛 {rec.pScore}/50</span></div></div></div>;})}
      </Card>}
    </div>
  );
};

// ══ PROFILE + Q SCREENS ══════════════════════════════════
const ProfileScreen=({session,onNext,onBack})=>{
  const[p,setP]=useState({name:session?.name||"",age:"",gender:"male",height:"",weight:"",dept:"",orgRole:"",industry:"科技業",shiftWork:"否",hypertension:"否",diabetes:"否",hyperlipidemia:"否",heartDisease:"否",smoking:"否",exercise:"每週1–2次",medications:"無",painLocations:[]});
  const up=useCallback((k,v)=>setP(x=>({...x,[k]:v})),[]);
  const bmi=p.height&&p.weight?(p.weight/((p.height/100)**2)).toFixed(1):null;
  return (
    <div>
      <h2 style={{color:C.text,fontSize:16,marginBottom:12}}>👤 個人健康資料</h2>
      <Card style={{marginBottom:11}}>
        <div style={{fontSize:11,color:C.teal,fontWeight:700,marginBottom:9}}>▸ 基本資料</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:9}}><F label="姓名 / 代稱" mb={0}><Inp value={p.name} onChange={v=>up("name",v)} placeholder="姓名或代稱"/></F><F label="年齡（歲）" mb={0}><Inp value={p.age} onChange={v=>up("age",v)} type="number" placeholder="年齡"/></F></div>
        <F label="性別" mb={9}><div style={{display:"flex",gap:6}}>{[["male","男性"],["female","女性"],["other","其他"]].map(([v,l])=><button key={v} onClick={()=>up("gender",v)} style={{flex:1,padding:"8px 4px",borderRadius:7,cursor:"pointer",fontSize:12,border:p.gender===v?`1.5px solid ${C.teal}`:`1px solid ${C.border}`,background:p.gender===v?C.tealBg:"#faf8f5",color:p.gender===v?C.teal:C.muted}}>{l}</button>)}</div></F>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:9}}><F label="身高（cm）" mb={0}><Inp value={p.height} onChange={v=>up("height",v)} type="number" placeholder="例：170"/></F><F label="體重（kg）" mb={0}><Inp value={p.weight} onChange={v=>up("weight",v)} type="number" placeholder="例：65"/></F></div>
        {bmi&&<div style={{background:C.tealBg,borderRadius:6,padding:"6px 10px",fontSize:11,color:C.teal,marginBottom:8}}>BMI：{bmi} — {bmi<18.5?"體重過輕":bmi<24?"正常範圍":bmi<27?"輕度過重":"過重/肥胖"}</div>}
        {session?.orgName&&<div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9}}><F label="部門" mb={0}><Inp value={p.dept} onChange={v=>up("dept",v)} placeholder="例：研發部"/></F><F label="職稱" mb={0}><Inp value={p.orgRole} onChange={v=>up("orgRole",v)} placeholder="例：工程師"/></F></div>}
      </Card>
      <Card style={{marginBottom:11}}>
        <div style={{fontSize:11,color:C.coral,fontWeight:700,marginBottom:9}}>▸ 職場與慢病資訊</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:9}}><F label="行業別" mb={0}><Sel value={p.industry} onChange={v=>up("industry",v)} options={["科技業","金融業","製造業","醫療院所","教育機構","服務業/零售","政府/公部門","其他"]}/></F><F label="輪班情況" mb={0}><Sel value={p.shiftWork} onChange={v=>up("shiftWork",v)} options={["否","日夜輪班","大夜班（固定）","早晚班"]}/></F></div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:9}}><F label="高血壓" mb={0}><Sel value={p.hypertension} onChange={v=>up("hypertension",v)} options={["否","是（已控制）","是（未控制）","邊緣值"]}/></F><F label="糖尿病" mb={0}><Sel value={p.diabetes} onChange={v=>up("diabetes",v)} options={["否","第一型","第二型","前期"]}/></F><F label="高血脂" mb={0}><Sel value={p.hyperlipidemia} onChange={v=>up("hyperlipidemia",v)} options={["否","是（已用藥）","是（飲食控制）","邊緣值"]}/></F><F label="心臟疾病" mb={0}><Sel value={p.heartDisease} onChange={v=>up("heartDisease",v)} options={["否","冠狀動脈疾病","心律不整","其他"]}/></F></div>
        <F label="疼痛部位（可複選）"><Multi value={p.painLocations} onChange={v=>up("painLocations",v)} options={PAIN_LOCS}/></F>
        <F label="目前長期用藥" mb={0}><Inp value={p.medications} onChange={v=>up("medications",v)} placeholder="如：降壓藥、止痛藥，無則填無"/></F>
      </Card>
      <div style={{display:"flex",gap:9}}><button onClick={onBack} style={{flex:1,padding:"11px",borderRadius:8,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,cursor:"pointer",fontSize:13}}>← 返回</button><button onClick={()=>(p.name&&p.age)&&onNext({...p,bmi})} style={{flex:2,padding:"11px",borderRadius:8,border:"none",background:`linear-gradient(135deg,${C.teal},#1a6474)`,color:"#fff",fontSize:13,fontWeight:600,cursor:"pointer"}}>下一步 →</button></div>
    </div>
  );
};

const SleepQ=({ans,setAns,onNext,onBack})=>{const done=Object.keys(ans).length===SQ.length;return <div><div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}><h2 style={{margin:0,color:C.text,fontSize:16}}>🌙 睡眠品質評估</h2><span style={{fontSize:10,color:C.teal,background:C.tealBg,padding:"3px 9px",borderRadius:20}}>ISI · 7題</span></div><div style={{marginBottom:12}}><div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:C.faint,marginBottom:3}}><span>{Object.keys(ans).length}/7</span><span>{Math.round(Object.keys(ans).length/7*100)}%</span></div><div style={{height:3,background:"#f0e8e0",borderRadius:4}}><div style={{height:"100%",borderRadius:4,width:`${Object.keys(ans).length/7*100}%`,background:`linear-gradient(90deg,${C.teal},${C.teal}cc)`,transition:"width .3s"}}/></div></div>{SQ.map((q,i)=><div key={q.id} style={{background:ans[q.id]!==undefined?C.tealBg:"#fff",border:`1px solid ${ans[q.id]!==undefined?C.tealLight:C.border}`,borderRadius:11,padding:"13px",marginBottom:9}}><div style={{display:"flex",gap:8,marginBottom:10}}><div style={{background:C.tealBg,borderRadius:7,width:28,height:28,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>{q.icon}</div><div><div style={{fontSize:9,color:C.teal,letterSpacing:1.2,textTransform:"uppercase",marginBottom:1}}>Q{i+1} · {q.d}</div><div style={{fontSize:12,color:C.text,lineHeight:1.55}}>{q.text}</div></div></div><div style={{display:"flex",flexDirection:"column",gap:5}}>{q.opts.map(o=><button key={o.s} onClick={()=>setAns(a=>({...a,[q.id]:o.s}))} style={{padding:"7px 11px",borderRadius:7,cursor:"pointer",textAlign:"left",display:"flex",alignItems:"center",gap:7,fontSize:11,border:ans[q.id]===o.s?`1.5px solid ${C.teal}`:`1px solid ${C.border}`,background:ans[q.id]===o.s?C.tealBg:"#faf8f5",color:ans[q.id]===o.s?C.teal:C.muted}}><span style={{width:9,height:9,borderRadius:"50%",flexShrink:0,border:ans[q.id]===o.s?`3px solid ${C.teal}`:`2px solid ${C.faint}`}}/><span style={{color:C.faint,marginRight:2,fontSize:10}}>{o.s}分</span>{o.l}</button>)}</div></div>)}<div style={{display:"flex",gap:9,marginTop:6}}><button onClick={onBack} style={{flex:1,padding:"11px",borderRadius:8,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,cursor:"pointer",fontSize:13}}>← 返回</button><button onClick={()=>done&&onNext()} disabled={!done} style={{flex:2,padding:"11px",borderRadius:8,border:"none",background:done?`linear-gradient(135deg,${C.teal},#1a6474)`:"#e8ddd4",color:done?"#fff":C.faint,fontSize:13,fontWeight:600,cursor:done?"pointer":"not-allowed"}}>{done?"前往疼痛評估 →":`尚餘 ${7-Object.keys(ans).length} 題`}</button></div></div>;};
const PainQ=({ans,setAns,onNext,onBack})=>{const done=Object.keys(ans).length===PQ.length;return <div><div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}><h2 style={{margin:0,color:C.text,fontSize:16}}>🩺 疼痛影響評估</h2><span style={{fontSize:10,color:C.coral,background:C.coralBg,padding:"3px 9px",borderRadius:20}}>BPI · 5題</span></div><div style={{marginBottom:12}}><div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:C.faint,marginBottom:3}}><span>{Object.keys(ans).length}/5</span><span>{Math.round(Object.keys(ans).length/5*100)}%</span></div><div style={{height:3,background:"#f0e8e0",borderRadius:4}}><div style={{height:"100%",borderRadius:4,width:`${Object.keys(ans).length/5*100}%`,background:`linear-gradient(90deg,${C.coral},${C.coral}cc)`,transition:"width .3s"}}/></div></div>{PQ.map((q,i)=><div key={q.id} style={{background:ans[q.id]!==undefined?C.coralBg:"#fff",border:`1px solid ${ans[q.id]!==undefined?"#f0b898":C.border}`,borderRadius:11,padding:"13px",marginBottom:9}}><div style={{display:"flex",gap:8,marginBottom:10}}><div style={{background:C.coralBg,borderRadius:7,width:28,height:28,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>{q.icon}</div><div><div style={{fontSize:9,color:C.coral,letterSpacing:1.2,textTransform:"uppercase",marginBottom:1}}>Q{i+1} · {q.d}</div><div style={{fontSize:12,color:C.text,lineHeight:1.55}}>{q.text}</div></div></div><NRS value={ans[q.id]??null} onChange={v=>setAns(a=>({...a,[q.id]:v}))}/>{ans[q.id]!==undefined&&<div style={{textAlign:"center",fontSize:10,color:C.muted,marginTop:5}}>已選：<strong style={{color:C.text}}>{ans[q.id]}</strong> 分</div>}</div>)}<div style={{display:"flex",gap:9,marginTop:6}}><button onClick={onBack} style={{flex:1,padding:"11px",borderRadius:8,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,cursor:"pointer",fontSize:13}}>← 返回</button><button onClick={()=>done&&onNext()} disabled={!done} style={{flex:2,padding:"11px",borderRadius:8,border:"none",background:done?`linear-gradient(135deg,${C.coral},#a84820)`:"#e8ddd4",color:done?"#fff":C.faint,fontSize:13,fontWeight:600,cursor:done?"pointer":"not-allowed"}}>{done?"前往工作效率評估 →":`尚餘 ${5-Object.keys(ans).length} 題`}</button></div></div>;};
const WorkQ=({ans,setAns,onNext,onBack})=>{const done=Object.keys(ans).length===WQ.length;return <div><div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}><h2 style={{margin:0,color:C.text,fontSize:16}}>💼 工作效率影響</h2><span style={{fontSize:10,color:C.amber,background:C.amberBg,padding:"3px 9px",borderRadius:20}}>3題</span></div>{WQ.map((q,i)=><div key={q.id} style={{background:ans[q.id]!==undefined?C.amberBg:"#fff",border:`1px solid ${ans[q.id]!==undefined?"#f0d898":C.border}`,borderRadius:11,padding:"13px",marginBottom:9}}><div style={{display:"flex",gap:8,marginBottom:10}}><div style={{background:C.amberBg,borderRadius:7,width:28,height:28,flexShrink:0,display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>💼</div><div><div style={{fontSize:9,color:C.amber,letterSpacing:1.2,textTransform:"uppercase",marginBottom:1}}>W{i+1} · {q.d}</div><div style={{fontSize:12,color:C.text,lineHeight:1.55}}>{q.text}</div></div></div><NRS value={ans[q.id]??null} onChange={v=>setAns(a=>({...a,[q.id]:v}))}/></div>)}<div style={{display:"flex",gap:9,marginTop:6}}><button onClick={onBack} style={{flex:1,padding:"11px",borderRadius:8,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,cursor:"pointer",fontSize:13}}>← 返回</button><button onClick={()=>done&&onNext()} disabled={!done} style={{flex:2,padding:"11px",borderRadius:8,border:"none",background:done?`linear-gradient(135deg,${C.amber},#9b6008)`:"#e8ddd4",color:done?"#fff":C.faint,fontSize:13,fontWeight:600,cursor:done?"pointer":"not-allowed"}}>{done?"產生個人化報告 →":`尚餘 ${3-Object.keys(ans).length} 題`}</button></div></div>;};

const LoadingScreen=()=>{
  const[step,setStep]=useState(0);
  const steps=["分析睡眠評估…","分析疼痛評估…","整合工作效率…","結合慢病資訊…","結合2022–2025研究…","生成個人化建議…","結合REIBI療程建議…","編製報告中…"];
  useEffect(()=>{const t=setInterval(()=>setStep(p=>p<steps.length-1?p+1:p),720);return()=>clearInterval(t);},[]);
  return <div style={{textAlign:"center",padding:"38px 10px"}}><div style={{fontSize:42,marginBottom:12,display:"inline-block",animation:"spin 2s linear infinite"}}>🌿</div><style>{`@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}`}</style><h2 style={{color:C.text,fontSize:18,marginBottom:4}}>正在生成個人化報告</h2><p style={{color:C.muted,fontSize:11,marginBottom:19}}>AI · 台灣健康政策 · 循證醫學</p>{steps.map((s,i)=><div key={i} style={{display:"flex",alignItems:"center",gap:8,padding:"7px 12px",borderRadius:7,marginBottom:5,background:i<=step?C.tealBg:"#faf8f5",border:i===step?`1px solid ${C.tealLight}`:"1px solid transparent",transition:"all .3s"}}><span style={{fontSize:11}}>{i<step?"✅":i===step?"⟳":"○"}</span><span style={{fontSize:11,color:i<=step?C.teal:C.faint}}>{s}</span></div>)}</div>;
};

// ══ REPORT SCREEN ════════════════════════════════════════
const ReportScreen=({report,session,onBack,onHistory,onAnalysis})=>{
  const{profile={},sScore=0,sLevel={key:"green",label:""},sAns={},pScore=0,pLevel={key:"green",label:""},pAns={},wScore=0,recs={},ts,id=""}=report||{};
  if(!report||!sLevel?.key)return <div style={{textAlign:"center",padding:40,color:C.muted}}>報告載入中…</div>;
  const comorbid=["yellow","orange","red"].includes(sLevel.key)&&["yellow","orange","red"].includes(pLevel.key);
  const date=new Date(ts).toLocaleDateString("zh-TW",{year:"numeric",month:"long",day:"numeric"});
  const openPDF=()=>{const html=buildPDF(report,session);const blob=new Blob([html],{type:"text/html;charset=utf-8"});const url=URL.createObjectURL(blob);window.open(url,"_blank");setTimeout(()=>URL.revokeObjectURL(url),15000);};
  const Rec=({icon,title,content,accent})=><div style={{background:"#fdf9f6",borderLeft:`4px solid ${accent}`,borderRadius:"0 9px 9px 0",padding:"10px 13px",marginBottom:9}}><div style={{display:"flex",alignItems:"center",gap:6,marginBottom:5}}><span style={{fontSize:13}}>{icon}</span><strong style={{fontSize:10,color:accent}}>{title}</strong></div><p style={{margin:0,fontSize:11,color:"#4a3c38",lineHeight:1.85}}>{content||"內容生成中…"}</p></div>;
  return <div>
    <div style={{display:"flex",gap:7,marginBottom:13,flexWrap:"wrap"}}>
      <button onClick={onBack} style={{padding:"7px 12px",borderRadius:7,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,fontSize:11,cursor:"pointer"}}>← 主選單</button>
      {can(session.systemRole,"dl_own")&&<button onClick={openPDF} style={{padding:"7px 13px",borderRadius:7,border:"none",background:`linear-gradient(135deg,${C.teal},#1a6474)`,color:"#fff",fontSize:11,fontWeight:600,cursor:"pointer"}}>🖨️ 列印 / 下載 PDF</button>}
      {can(session.systemRole,"view_history")&&<button onClick={onHistory} style={{padding:"7px 12px",borderRadius:7,border:`1px solid #7ecfaa`,background:"#edf7f3",color:"#2d7a5a",fontSize:11,fontWeight:600,cursor:"pointer"}}>📈 年度追蹤</button>}
      {can(session.systemRole,"view_history")&&onAnalysis&&<button onClick={onAnalysis} style={{padding:"7px 11px",borderRadius:7,border:"none",background:C.teal,color:"#fff",fontSize:11,fontWeight:600,cursor:"pointer"}}>📊 健康分析</button>}
    </div>
    <div style={{background:`linear-gradient(135deg,${C.teal},#1a6474)`,borderRadius:14,padding:"22px",marginBottom:13,color:"#fff",textAlign:"center"}}>
      <div style={{fontSize:9,letterSpacing:2,opacity:.7,marginBottom:6}}>麗媚生化科技 REIBI · 健康管理評估報告</div>
      <h1 style={{fontSize:"clamp(15px,4vw,20px)",fontWeight:700,margin:"0 0 3px"}}>睡眠 × 疼痛聯合評估報告</h1>
      <div style={{display:"flex",justifyContent:"center",flexWrap:"wrap",gap:10,background:"rgba(255,255,255,.12)",borderRadius:8,padding:"8px 13px",margin:"11px 0"}}>{[["對象",profile.name||"匿名"],["年齡",`${profile.age||"—"}歲`],["日期",date]].map(([l,v])=><div key={l} style={{textAlign:"center"}}><div style={{fontSize:8,opacity:.6,marginBottom:1}}>{l}</div><div style={{fontSize:11,fontWeight:600}}>{v}</div></div>)}</div>
      <div style={{display:"flex",justifyContent:"center",gap:8,flexWrap:"wrap"}}>{[{l:"睡眠",s:sScore,m:28,lv:sLevel},{l:"疼痛",s:pScore,m:50,lv:pLevel},{l:"工作",s:wScore,m:30,lv:{key:(wScore||0)<=10?"green":(wScore||0)<=20?"yellow":"orange"}}].map(x=><div key={x.l} style={{background:LX[x.lv.key].bg,border:`2px solid ${LX[x.lv.key].br}`,borderRadius:8,padding:"7px 11px",textAlign:"center",minWidth:82}}><div style={{fontSize:9,color:C.muted,marginBottom:1}}>{x.l}</div><div style={{fontSize:16,fontWeight:700,color:LX[x.lv.key].c}}>{x.s}<span style={{fontSize:9}}>/{x.m}</span></div><div style={{fontSize:9,color:LX[x.lv.key].c,fontWeight:600}}>{LL[x.lv.key]}</div></div>)}</div>
    </div>
    <Card>
      {[{q:SQ,ans:sAns,lv:sLevel,score:sScore,max:28,label:"🌙 睡眠評估（ISI）",maxI:4},{q:PQ,ans:pAns,lv:pLevel,score:pScore,max:50,label:"🩺 疼痛評估（BPI）",maxI:10}].map(sec=><div key={sec.label} style={{marginBottom:18}}><div style={{fontSize:13,fontWeight:700,color:C.text,borderBottom:`1px solid ${C.divider}`,paddingBottom:6,marginBottom:10}}>{sec.label}</div><div style={{display:"flex",gap:10,background:LX[sec.lv.key].bg,border:`1.5px solid ${LX[sec.lv.key].br}`,borderRadius:9,padding:"10px 12px",marginBottom:8,alignItems:"flex-start"}}><TL active={sec.lv.key}/><div><div style={{fontSize:9,color:C.muted,marginBottom:2}}>{sec.score}/{sec.max} · {sec.lv.range}分</div><div style={{fontSize:17,fontWeight:700,color:LX[sec.lv.key].c}}>{LL[sec.lv.key]} {sec.lv.label}</div><p style={{margin:"3px 0 2px",fontSize:11,color:"#4a3c38"}}>{sec.lv.desc}</p><p style={{margin:0,fontSize:11,color:LX[sec.lv.key].c,fontWeight:600}}>▸ {sec.lv.action}</p></div></div>{sec.q.map(q=><div key={q.id} style={{marginBottom:5}}><div style={{fontSize:10,color:C.muted,marginBottom:2}}>{q.icon} {q.d}</div><PBar score={sec.ans[q.id]??0} max={sec.maxI}/></div>)}</div>)}
      {comorbid&&<div style={{background:"#fff9f0",border:`1.5px solid #f5c88a`,borderRadius:8,padding:"10px 13px",marginBottom:15}}><div style={{fontSize:11,fontWeight:700,color:"#8a5a00",marginBottom:4}}>⚠️ 疼痛–睡眠共病警示</div><p style={{fontSize:11,color:"#6b4000",lineHeight:1.8,margin:0}}>您同時存在疼痛與睡眠問題，提示「疼痛–失眠惡性循環」。建議整合治療（藥物+CBT-I）並告知醫師。</p></div>}
      <div style={{borderTop:`1px solid ${C.divider}`,paddingTop:13}}><div style={{fontSize:12,fontWeight:700,color:C.text,marginBottom:10}}>💡 個人化健康促進建議（2022–2025）</div><Rec icon="🏃" title="綜合健康促進" content={recs.generalHealth} accent={C.teal}/><Rec icon="💊" title="疼痛衛教建議" content={recs.painEducation} accent={C.coral}/><Rec icon="🌙" title="睡眠衛教建議" content={recs.sleepEducation} accent="#6b54a0"/><Rec icon="🥗" title="飲食衛教建議" content={recs.dietaryAdvice} accent={C.sage}/><Rec icon="🤸" title="物理治療建議" content={recs.physicalTherapy} accent={C.amber}/><div style={{background:"linear-gradient(135deg,#ebf6f8,#eef0fb)",border:`1.5px solid ${C.tealLight}`,borderRadius:9,padding:"11px 13px"}}><div style={{fontSize:11,fontWeight:700,color:"#1a6074",marginBottom:4}}>🔬 麗媚生化科技 REIBI · 舒曼波 &amp; LA200 雷射治療</div><p style={{margin:0,fontSize:11,color:"#2c4a52",lineHeight:1.85}}>{recs.reibiProducts||""}</p></div></div>
    </Card>
  </div>;
};

// ══ HISTORY SCREEN ═══════════════════════════════════════
const HistoryScreen=({reports=[],session,onBack,onNew,onAnalysis=()=>{}})=>{
  const[dateFrom,setDateFrom]=useState("");
  const[dateTo,setDateTo]=useState("");
  const safe=Array.isArray(reports)?reports:[];
  const filtered=safe.filter(r=>{const d=r.ts?.slice(0,10)||"";return(!dateFrom||d>=dateFrom)&&(!dateTo||d<=dateTo);});
  const sorted=[...filtered].sort((a,b)=>new Date(a.ts)-new Date(b.ts));
  const openPDF=(r)=>{const html=buildPDF(r,session);const blob=new Blob([html],{type:"text/html;charset=utf-8"});const url=URL.createObjectURL(blob);window.open(url,"_blank");setTimeout(()=>URL.revokeObjectURL(url),15000);};
  if(!safe.length)return <div style={{textAlign:"center",padding:"38px 20px"}}><div style={{fontSize:34,marginBottom:11}}>📈</div><h2 style={{color:C.text,marginBottom:7}}>尚無歷史記錄</h2><div style={{display:"flex",gap:9,justifyContent:"center"}}><button onClick={onBack} style={{padding:"10px 16px",borderRadius:8,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,cursor:"pointer"}}>← 返回</button><button onClick={onNew} style={{padding:"10px 16px",borderRadius:8,border:"none",background:`linear-gradient(135deg,${C.teal},#1a6474)`,color:"#fff",cursor:"pointer"}}>開始評估</button></div></div>;
  return <div>
    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:14}}><h2 style={{margin:0,color:C.text,fontSize:16}}>📈 年度健康追蹤</h2><div style={{display:"flex",gap:7}}>{can(session.systemRole,"view_history")&&<button onClick={onAnalysis} style={{padding:"7px 11px",borderRadius:7,border:"none",background:C.teal,color:"#fff",fontSize:11,fontWeight:600,cursor:"pointer"}}>📊 健康分析</button>}<button onClick={onBack} style={{padding:"7px 12px",borderRadius:7,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,fontSize:11,cursor:"pointer"}}>← 返回</button></div></div>
    {/* Date filter */}
    <Card style={{marginBottom:11}}>
      <div style={{fontSize:11,color:C.teal,fontWeight:600,marginBottom:8}}>📅 依日期區間查詢</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:8}}>
        <F label="起始日期" mb={0}><input type="date" value={dateFrom} onChange={e=>setDateFrom(e.target.value)} style={{width:"100%",padding:"8px 10px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:12,outline:"none",boxSizing:"border-box"}}/></F>
        <F label="結束日期" mb={0}><input type="date" value={dateTo} onChange={e=>setDateTo(e.target.value)} style={{width:"100%",padding:"8px 10px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:12,outline:"none",boxSizing:"border-box"}}/></F>
      </div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <span style={{fontSize:11,color:C.muted}}>顯示 {filtered.length}/{safe.length} 筆記錄</span>
        {(dateFrom||dateTo)&&<button onClick={()=>{setDateFrom("");setDateTo("");}} style={{padding:"4px 10px",borderRadius:7,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,fontSize:11,cursor:"pointer"}}>清除篩選</button>}
