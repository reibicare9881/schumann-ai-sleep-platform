      {(isAdmin&&editROI)&&<div style={{background:C.plumBg,border:`1px solid ${C.plum}33`,borderRadius:9,padding:"12px",marginBottom:11}}>
        <div style={{fontSize:11,color:C.plum,fontWeight:700,marginBottom:9}}>⚙️ 管理者可修改（依公司自行評估）</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9}}>
          <F label="因識能提升減少病假天數/人/年" mb={0}><NumInp value={sickDays} onChange={setSickDays} min={0} max={30} suffix="天"/></F>
          <F label="平均日薪（元）" mb={0}><NumInp value={dailySalary} onChange={setDailySalary} min={0} step={500} prefix="NT$"/></F>
          <F label="每人醫療保險成本節省（元/年）" mb={0}><NumInp value={insSaving} onChange={setInsSaving} min={0} step={1000} prefix="NT$"/></F>
