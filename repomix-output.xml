    {/* Date & dept filters */}
    <Card style={{marginBottom:11}}>
      <div style={{fontSize:11,color:C.teal,fontWeight:600,marginBottom:9}}>📅 日期區間篩選</div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:9,marginBottom:9}}>
        <F label="起始日期" mb={0}><input type="date" value={dateFrom} onChange={e=>setDateFrom(e.target.value)} style={{width:"100%",padding:"7px 9px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:11,outline:"none",boxSizing:"border-box"}}/></F>
        <F label="結束日期" mb={0}><input type="date" value={dateTo} onChange={e=>setDateTo(e.target.value)} style={{width:"100%",padding:"7px 9px",border:`1px solid ${C.border}`,borderRadius:7,background:"#faf8f5",fontSize:11,outline:"none",boxSizing:"border-box"}}/></F>
      </div>
      {isAdmin&&depts.length>0&&<div><div style={{fontSize:10,color:C.muted,marginBottom:6}}>部門篩選</div><div style={{display:"flex",gap:6,flexWrap:"wrap"}}>{["全部",...depts].map(d=><button key={d} onClick={()=>setFDept(d)} style={{padding:"4px 10px",borderRadius:7,fontSize:10,cursor:"pointer",border:fDept===d?`1.5px solid ${C.teal}`:`1px solid ${C.border}`,background:fDept===d?C.tealBg:"#faf8f5",color:fDept===d?C.teal:C.muted}}>{d}</button>)}</div></div>}
      <div style={{fontSize:10,color:C.muted,marginTop:8}}>顯示 {n}/{allData.length} 筆記錄</div>
    </Card>
    <Card style={{marginBottom:11,background:"linear-gradient(135deg,#ebf6f8,#f0f4fb)",border:`1px solid ${C.tealLight}`}}>
      <div style={{fontSize:11,color:C.teal,fontWeight:700,marginBottom:9}}>🏆 健康促進指數 HPI</div>
      <div style={{display:"flex",alignItems:"center",gap:13}}><div style={{textAlign:"center"}}><div style={{fontSize:38,fontWeight:700,color:hc}}>{HPI}</div><div style={{fontSize:9,color:C.muted}}>/100</div><div style={{fontSize:10,fontWeight:600,color:hc}}>{HPI>=75?"良好":HPI>=50?"需關注":"高風險"}</div></div><div style={{flex:1}}><div style={{height:7,background:"#f0e8e0",borderRadius:4,marginBottom:6,overflow:"hidden"}}><div style={{height:"100%",width:`${HPI}%`,background:`linear-gradient(90deg,${hc},${hc}aa)`,borderRadius:4}}/></div><div style={{fontSize:10,color:C.muted,lineHeight:1.8}}><div>• 睡眠 {Math.round(100-avgS/28*100)}/100</div><div>• 疼痛 {Math.round(100-avgP/50*100)}/100</div><div>• 工作 {Math.round(100-avgW/30*100)}/100</div></div></div></div>
    </Card>
    <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8,marginBottom:11}}>{[{icon:"👥",l:"評估人次",v:n,c:C.teal},{icon:"🔴",l:"睡眠高風險",v:`${Math.round(sHighRisk/n*100)}%`,c:"#b82020"},{icon:"⚠️",l:"共病率",v:`${Math.round(cb/n*100)}%`,c:C.coral}].map(s=><div key={s.l} style={{background:"#fff",border:`1px solid ${C.border}`,borderRadius:9,padding:"11px 7px",textAlign:"center"}}><div style={{fontSize:18,marginBottom:3}}>{s.icon}</div><div style={{fontSize:16,fontWeight:700,color:s.c}}>{s.v}</div><div style={{fontSize:9,color:C.muted,marginTop:1,lineHeight:1.4}}>{s.l}</div></div>)}</div>
    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:11}}><Card><div style={{fontSize:10,color:C.teal,fontWeight:600,marginBottom:8}}>睡眠分佈</div><DBar dist={sDist}/></Card><Card><div style={{fontSize:10,color:C.coral,fontWeight:600,marginBottom:8}}>疼痛分佈</div><DBar dist={pDist}/></Card></div>
    {topLocs.length>0&&<Card style={{marginBottom:11}}><div style={{fontSize:10,color:C.coral,fontWeight:700,marginBottom:8}}>🗺 疼痛主要部位（前5）</div>{topLocs.map(([loc,cnt])=>{const p=Math.round(cnt/n*100);return <div key={loc} style={{display:"flex",alignItems:"center",gap:8,marginBottom:7}}><div style={{width:85,fontSize:10,color:C.text}}>{loc}</div><div style={{flex:1,height:14,background:"#f0e8e0",borderRadius:3,overflow:"hidden"}}><div style={{height:"100%",width:`${p}%`,background:C.coral,borderRadius:3,display:"flex",alignItems:"center",justifyContent:"flex-end",paddingRight:3}}>{p>15&&<span style={{fontSize:8,color:"#fff",fontWeight:700}}>{p}%</span>}</div></div><div style={{fontSize:10,color:C.coral,fontWeight:600,minWidth:28}}>{cnt}人</div></div>;})}</Card>}
    {/* KPI Formulas */}
    <Card style={{marginBottom:11}}>
      <div style={{fontSize:11,color:C.plum,fontWeight:700,marginBottom:11}}>📐 KPI計算公式（以本單位數據）</div>
      {[{num:"1",label:"改善率 Improvement Rate ★ 主要KPI",formula:"改善人數 ÷ 有問題人數 × 100%",calc:`${sGreen} ÷ ${sHighRisk} × 100%`,pct:improvePct,color:improvePct>=70?"#2d7a5a":improvePct>=50?"#b07015":"#b82020",desc:"改善率 ≥75% 為優異表現，代表方案具高度介入價值。"},
        {num:"2",label:"問題盛行率 Prevalence Rate",formula:"有問題人數 ÷ 總人數 × 100%",calc:`${sHighRisk} ÷ ${n} × 100%`,pct:prevalencePct,color:"#b07015",desc:"衡量群體問題嚴重程度的現狀指標。"},
        {num:"3",label:"全體健康貢獻率 Total Impact Rate",formula:"改善人數 ÷ 總人數 × 100%",calc:`${sGreen} ÷ ${n} × 100%`,pct:impactPct,color:"#6b4a8c",desc:"衡量健促方案對整個人群帶來的總體提升。"},
      ].map(f=><div key={f.num} style={{background:f.num==="1"?"linear-gradient(135deg,#ebf6f8,#edf7f3)":"#faf8f5",border:`1px solid ${f.num==="1"?C.tealLight:C.border}`,borderRadius:10,padding:"11px 12px",marginBottom:9}}>
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:6}}><div style={{width:20,height:20,borderRadius:"50%",background:f.color,color:"#fff",fontSize:9,fontWeight:700,display:"flex",alignItems:"center",justifyContent:"center",flexShrink:0}}>{f.num}</div><div style={{fontSize:11,fontWeight:700,color:C.text}}>{f.label}</div>{f.num==="1"&&<span style={{marginLeft:"auto",fontSize:9,color:C.teal,background:C.tealBg,padding:"2px 8px",borderRadius:20}}>主要KPI ★</span>}</div>
        <div style={{background:"#fff",borderRadius:7,padding:"7px 10px",marginBottom:6,fontSize:10,color:C.text}}><strong>公式：</strong>{f.formula}</div>
        <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:5}}><div style={{flex:1,fontSize:10,color:C.muted}}>{f.calc}</div><div style={{fontSize:22,fontWeight:700,color:f.color}}>{f.pct}%</div></div>
        <div style={{height:6,background:"#f0e8e0",borderRadius:4,overflow:"hidden",marginBottom:5}}><div style={{height:"100%",width:`${Math.min(f.pct,100)}%`,background:f.color,borderRadius:4}}/></div>
        <p style={{fontSize:10,color:C.muted,margin:0,lineHeight:1.6}}>{f.desc}</p>
      </div>)}
