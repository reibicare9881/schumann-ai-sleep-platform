          {/* 長條圖分布 */}
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
            <div className="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
              <h3 className="text-sm font-bold text-indigo-700 mb-2">🌙 睡眠風險層級分布</h3>
              <DistBar dist={sDist} />
