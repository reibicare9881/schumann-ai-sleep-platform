const genRecs=async(prof,sT,sLv,pT,pLv,wT)=>{
  try{
    const ctrl=new AbortController();
    setTimeout(()=>ctrl.abort(),7000);
    const r=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",signal:ctrl.signal,headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1800,messages:[{role:"user",content:`台灣健康管理顧問，2022–2025循證醫學，個人化建議。回傳純JSON，6鍵，各150字繁體，直接從{開始。年齡${prof.age||"—"} 睡眠${sT}/28→${sLv.label} 疼痛${pT}/50→${pLv.label}\n{"generalHealth":"","painEducation":"","sleepEducation":"","dietaryAdvice":"","physicalTherapy":"","reibiProducts":""}`}]})});
    const d=await r.json();
    const txt=d.content?.find(b=>b.type==="text")?.text||"";
    const m=txt.match(/\{[\s\S]*\}/);
    if(!m)return FR;
    const p=JSON.parse(m[0]);
    return["generalHealth","painEducation","sleepEducation","dietaryAdvice","physicalTherapy","reibiProducts"].every(k=>p[k]?.length>20)?p:FR;
  }catch{return FR;}
};

