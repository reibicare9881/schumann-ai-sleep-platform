            <div className="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
              <h3 className="text-sm font-bold text-rose-700 mb-2">🩺 疼痛風險層級分布</h3>
              <DistBar dist={pDist} />
            </div>
