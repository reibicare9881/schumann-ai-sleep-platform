// ══ HIGH RISK PANEL (for Org Admin) ══════════════════════
const HighRiskPanel=({data=[],session,onBack})=>{
  const highRisk=data.filter(r=>["orange","red"].includes(r.sKey)||["orange","red"].includes(r.pKey));
  const comorbid=data.filter(r=>["orange","red"].includes(r.sKey)&&["orange","red"].includes(r.pKey));
  const stale30=data.filter(r=>{const d=r.ts?new Date(r.ts):null;return d&&(Date.now()-d.getTime())>30*86400000;});
  const sDist={red:0,orange:0,yellow:0,green:0};
  const pDist={red:0,orange:0,yellow:0,green:0};
  data.forEach(r=>{if(r.sKey&&sDist[r.sKey]!==undefined)sDist[r.sKey]++;if(r.pKey&&pDist[r.pKey]!==undefined)pDist[r.pKey]++;});
  const n=data.length||1;
  const BulletBar=({pct,color,label,count})=>(
    <div style={{marginBottom:9}}>
      <div style={{display:"flex",justifyContent:"space-between",fontSize:10,marginBottom:3}}>
        <span style={{color:C.muted}}>{label}</span><span style={{fontWeight:700,color}}>{count}人（{pct}%）</span>
      </div>
      <div style={{height:8,background:"#f0e8e0",borderRadius:4,overflow:"hidden"}}>
        <div style={{height:"100%",width:`${pct}%`,background:color,borderRadius:4}}/>
      </div>
    </div>
  );
  return(
    <div>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:14}}>
        <h2 style={{margin:0,color:C.text,fontSize:16}}>🔴 高風險族群分析</h2>
        <button onClick={onBack} style={{padding:"7px 12px",borderRadius:7,border:`1px solid ${C.border}`,background:"transparent",color:C.muted,fontSize:11,cursor:"pointer"}}>← 返回</button>
      </div>
      {/* Summary cards */}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:12}}>
        {[{icon:"🔴",l:"高風險人數",v:highRisk.length,sub:`佔 ${Math.round(highRisk.length/n*100)}%`,c:"#b82020"},
          {icon:"⚠️",l:"共病人數",v:comorbid.length,sub:"睡眠+疼痛",c:C.coral},
          {icon:"📅",l:"30天未評估",v:stale30.length,sub:"建議追蹤",c:C.amber}].map(s=>(
          <div key={s.l} style={{background:"#fff",border:`1px solid ${C.border}`,borderRadius:9,padding:"11px 7px",textAlign:"center",boxShadow:C.shadow}}>
            <div style={{fontSize:18,marginBottom:2}}>{s.icon}</div>
            <div style={{fontSize:20,fontWeight:700,color:s.c}}>{s.v}</div>
            <div style={{fontSize:9,color:C.muted,marginTop:1,lineHeight:1.4}}>{s.l}</div>
            <div style={{fontSize:8,color:s.c,marginTop:1}}>{s.sub}</div>
          </div>
        ))}
      </div>
      {/* Distribution breakdown */}
      <Card style={{marginBottom:11}}>
        <div style={{fontSize:11,fontWeight:700,color:C.teal,marginBottom:11}}>📊 員工健康分布（去識別化）</div>
        <div style={{fontSize:10,color:C.muted,marginBottom:8}}>🌙 睡眠分布</div>
        {Object.entries({red:"🔴 重度失眠",orange:"🟠 中度失眠",yellow:"🟡 輕度失眠",green:"🟢 睡眠良好"}).map(([k,label])=><BulletBar key={k} pct={Math.round(sDist[k]/n*100)} color={LX[k].c} label={label} count={sDist[k]}/>)}
        <div style={{fontSize:10,color:C.muted,marginBottom:8,marginTop:10}}>🩺 疼痛分布</div>
        {Object.entries({red:"🔴 極重度疼痛",orange:"🟠 重度疼痛",yellow:"🟡 中度疼痛",green:"🟢 疼痛輕微"}).map(([k,label])=><BulletBar key={k} pct={Math.round(pDist[k]/n*100)} color={LX[k].c} label={label} count={pDist[k]}/>)}
      </Card>
      {/* Retention alert */}
      {stale30.length>0&&<Card style={{background:"#fdf6e8",borderColor:"#f0c76a",marginBottom:11}}>
        <div style={{fontSize:11,fontWeight:700,color:C.amber,marginBottom:7}}>⚠️ 參與度預警（30天未評估）</div>
        <div style={{fontSize:10,color:"#6b4a10",lineHeight:1.7,marginBottom:8}}>
          共 <strong>{stale30.length} 位成員</strong>超過30天未完成健康評估，建議主動通知提醒，以維持資料完整性及健促計畫有效性。
        </div>
        <div style={{background:"#fff",borderRadius:8,padding:"9px 12px",fontSize:10,color:C.muted}}>
          建議行動：<br/>
          ① 透過單位內部通訊發送「健康評估提醒」<br/>
          ② 確認是否有角色通行碼或登入問題<br/>
          ③ 管理者可將參與率追蹤納入OKR KR2指標
        </div>
      </Card>}
      {/* Health intervention recommendations */}
      <Card>
        <div style={{fontSize:11,fontWeight:700,color:C.text,marginBottom:9}}>💡 高風險族群健促介入建議</div>
        <div style={{fontSize:10,color:"#b82020",background:"#fdf0f0",borderRadius:7,padding:"7px 11px",marginBottom:9}}>
          ⚠ 以下為組織層次的健促管理建議（僅供管理參考），不代表個別醫療診斷。高風險員工應在自願前提下獲得適當支援。
        </div>
        {[{icon:"🎯",t:"優先介入",d:"共病員工（同時有睡眠及疼痛問題）為高優先介入對象，可優先安排REIBI療程諮詢機會"},
          {icon:"📚",t:"衛教優先",d:"對橙燈/紅燈員工，優先提供睡眠衛教（CBT-I原則）及疼痛自我管理資訊"},
          {icon:"📋",t:"定期追蹤",d:"建議每8週進行一次重新評估，觀察燈號轉變（是否改善/持平/惡化）"},
          {icon:"🏥",t:"轉介建議",d:"對ISI≥22（重度失眠）或BPI≥39（極重度疼痛）的員工，建議提供員工協助方案（EAP）或轉介資訊"},
        ].map((item,i)=>(
          <div key={i} style={{display:"flex",gap:9,padding:"8px 10px",borderRadius:8,marginBottom:6,background:"#faf8f5",border:`1px solid ${C.border}`}}>
            <span style={{fontSize:16,flexShrink:0}}>{item.icon}</span>
            <div><div style={{fontSize:11,fontWeight:600,color:C.text,marginBottom:2}}>{item.t}</div><div style={{fontSize:10,color:C.muted,lineHeight:1.6}}>{item.d}</div></div>
          </div>
        ))}
      </Card>
    </div>
  );
};

