    const wScore = Object.values(wAns).reduce((a, b) => a + b, 0);
    
    const sLevel = getSR(sScore);
    const pLevel = getPR(pScore);

    const report = {
      id: Date.now().toString(36) + Math.random().toString(36).slice(2, 5),
