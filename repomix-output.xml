  const cb=fd.filter(r=>["yellow","orange","red"].includes(r.sKey)&&["yellow","orange","red"].includes(r.pKey)).length;
  const HPI=n>0?Math.round(100-((avgS/28*40)+(avgP/50*40)+(avgW/30*20))):0;
