    const b=new Blob([lines.join("\n")],{type:"text/plain;charset=utf-8"});const u=URL.createObjectURL(b);const a=document.createElement("a");a.href=u;a.download="KPI報告.txt";a.click();URL.revokeObjectURL(u);
