        <div>• 導入成本：<strong style={{color:C.coral}}>−NT${implCost.toLocaleString()}</strong></div>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
        <div style={{background:netROI>=0?"#edf7f3":"#fdf0f0",border:`1px solid ${netROI>=0?"#7ecfaa":"#f0a0a0"}`,borderRadius:9,padding:"11px",textAlign:"center"}}><div style={{fontSize:9,color:C.muted,marginBottom:2}}>年度淨效益</div><div style={{fontSize:18,fontWeight:700,color:netROI>=0?"#2d7a5a":"#b82020"}}>NT${Math.abs(netROI).toLocaleString()}</div></div>
