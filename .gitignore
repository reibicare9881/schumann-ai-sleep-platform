# ==========================================
# 1. Backend (FastAPI / Python)
# ==========================================
backend/venv/
backend/.venv/
backend/__pycache__/
backend/*.py[cod]
backend/*.so
backend/.python-version
backend/.pytest_cache/
backend/.mypy_cache/
backend/node_modules/
backend/dist/
backend/build/

# 暫存資料夾 (存放 AI 處理過程中的臨時 PDF/圖片)
backend/temp_files/
backend/output_reports/

# ==========================================
# 2. Frontend (Node.js / Next.js)
# ==========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.eslintcache
frontend/.vercel

# ==========================================
# 3. Environment Secrets (極度重要，絕不能上傳)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
frontend/.env.local

# ==========================================
# 4. IDEs & OS
# ==========================================
.vscode/
!.vscode/extensions.json  # 如果有推薦的擴充套件設定可以留下
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==========================================
# 5. Logs & Lock files
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 如果你使用 Supabase CLI 本地開發
.supabase/